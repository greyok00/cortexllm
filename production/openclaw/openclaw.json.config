{
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/qwen3.5:9b",
        "fallbacks": [
          "ollama/qwen3.5:cloud"
        ]
      },
      "skills": [
        "kill-switch",
        "auto-learn",
        "gcal-sync",
        "calendar-organize",
        "session-persistence",
        "self-improve",
        "searxng-search",
        "session-heartbeat"
      ],
      "contextTokens": 262144,
      "workspace": "~/.openclaw/workspace"
    },
    "list": [
      {
        "id": "brain",
        "default": true,
        "name": "Brain Agent",
        "description": "Master orchestrator",
        "workspace": "~/.openclaw/workspace",
        "model": {
          "primary": "ollama/qwen3.5:cloud",
          "fallbacks": [
            "ollama/deepseek-v4-flash:cloud"
          ]
        },
        "thinkingDefault": "medium",
        "tools": {
          "profile": "full"
        },
        "skills": []
      }
    ]
  },
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "GENERATE_YOUR_OWN_TOKEN"
    },
    "controlUi": {
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "brave",
    "profiles": {
      "brave": {
        "driver": "existing-session",
        "cdpUrl": "http://127.0.0.1:9222",
        "color": "#FB542B"
      }
    }
  },
  "plugins": {
    "entries": {
      "browser": {
        "enabled": true
      },
      "ollama": {
        "enabled": true
      },
      "searxng": {
        "enabled": true,
        "config": {
          "webSearch": {
            "baseUrl": "http://127.0.0.1:8888"
          }
        }
      }
    }
  },
  "tools": {
    "web": {
      "search": {
        "enabled": true,
        "provider": "searxng"
      },
      "fetch": {
        "enabled": true
      }
    },
    "profile": "coding"
  },
  "meta": {
    "lastTouchedVersion": "2026.6.6"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "models": {
    "mode": "merge",
    "providers": {
      "ollama": {
        "baseUrl": "http://127.0.0.1:11434",
        "api": "ollama",
        "apiKey": "OLLAMA_API_KEY",
        "models": [
          {
            "id": "qwen3.5:cloud",
            "name": "Qwen 3.5 Cloud (Primary/Reasoning)",
            "reasoning": true,
            "input": ["text", "image"],
            "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0},
            "contextWindow": 262144,
            "maxTokens": 8192,
            "compat": {
              "supportsTools": true,
              "supportsUsageInStreaming": true
            }
          },
          {
            "id": "deepseek-v4-flash:cloud",
            "name": "DeepSeek V4 Flash (Worker)",
            "reasoning": false,
            "input": ["text"],
            "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0},
            "contextWindow": 128000,
            "maxTokens": 8192,
            "compat": {
              "supportsTools": true,
              "supportsUsageInStreaming": true
            }
          }
        ]
      }
    }
  }
}
