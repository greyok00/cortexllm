{
  "mcpServers": {
    "cortexllm": {
      "command": "python3",
      "args": ["cortexllm_mcp_server.py"],
      "env": {
        "PYTHONPATH": "."
      },
      "description": "CortexLLM Unified Memory System - Universal memory for all AI agents",
      "capabilities": [
        "memory_read",
        "memory_write",
        "memory_search",
        "memory_clear"
      ]
    }
  }
}