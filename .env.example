# CortexLLM Environment Variables
# Copy this file to .env and fill in your values

# OpenClaw Gateway Authentication
# Required if using OpenClaw platform
OPENCLAW_GATEWAY_TOKEN=your_token_here

# Custom Config Path (optional)
# Default: ~/.config/cortexllm/config.json
# CORTEXLLM_CONFIG_PATH=~/.config/cortexllm/config.json

# Ollama Endpoint (optional)
# Default: http://127.0.0.1:11434
# OLLAMA_HOST=127.0.0.1:11434

# Browser CDP (optional - for browser automation)
# BRAVE_CDP_URL=http://127.0.0.1:9222

# Searxng Search (optional - for web search)
# SEARXNG_URL=http://127.0.0.1:8888
